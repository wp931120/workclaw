# WorkClaw Environment Variables
# Copy this file to .env and fill in your values

# App
WORKCLAW_DEBUG=true
WORKCLAW_SECRET_KEY=your-secret-key-change-in-production

# Database
WORKCLAW_DATABASE_URL=sqlite+aiosqlite:///./data/workclaw.db

# Auth (simplified local dev)
WORKCLAW_AUTH_MODE=local

# LLM - Anthropic
WORKCLAW_ANTHROPIC_API_KEY=
WORKCLAW_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# LLM - OpenAI (optional)
WORKCLAW_OPENAI_API_KEY=
WORKCLAW_OPENAI_MODEL=gpt-4o

# Permission
WORKCLAW_DEFAULT_PERMISSION_MODE=moderate